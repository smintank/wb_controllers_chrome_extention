{
  "manifest_version": 3,
  "name": "Wiren Board Tracker",
  "version": "0.1.0",
  "description": "Track visited local Wiren Board controllers and show their availability.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["http://*/", "https://*/"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
